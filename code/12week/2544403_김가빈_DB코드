DROP TABLE IF EXISTS class_code CASCADE;

-- 1. CREATE TABLE

CREATE TABLE class_code (
    code INTEGER PRIMARY KEY,
    class VARCHAR(20),
    basis VARCHAR(50)
);

CREATE TABLE task_code (
    code INTEGER PRIMARY KEY,
    task VARCHAR(50)
);

CREATE TABLE customer (
    id VARCHAR(15) PRIMARY KEY,
    name VARCHAR(20) NOT NULL,
    cell CHAR(13) NOT NULL UNIQUE,
    addr VARCHAR(100),
    c_code INTEGER NOT NULL DEFAULT 3,
    CONSTRAINT fk_customer_class
        FOREIGN KEY (c_code) REFERENCES class_code(code),
    CONSTRAINT chk_customer_class
        CHECK (c_code IN (1, 2, 3, 4, 5))
);

CREATE TABLE staff (
    staff_id INTEGER PRIMARY KEY,
    name VARCHAR(20) NOT NULL,
    birthday CHAR(6) NOT NULL,
    tel CHAR(12) UNIQUE,
    salary INTEGER DEFAULT 0,
    t_code INTEGER NOT NULL,
    hire_date CHAR(8) NOT NULL,
    CONSTRAINT fk_staff_task
        FOREIGN KEY (t_code) REFERENCES task_code(code),
    CONSTRAINT chk_staff_salary
        CHECK (salary >= 0)
);

CREATE TABLE tour (
    tour_num CHAR(8) PRIMARY KEY,
    departure VARCHAR(50) NOT NULL,
    arrival VARCHAR(50) NOT NULL,
    program VARCHAR(100),
    start_dt TIMESTAMP NOT NULL,
    end_dt TIMESTAMP NOT NULL,
    min_num INTEGER NOT NULL,
    max_num INTEGER NOT NULL,
    expense INTEGER NOT NULL,
    deposit INTEGER DEFAULT 15000,
    dep_yn CHAR(1) DEFAULT 'N',
    staff_id INTEGER NOT NULL,
    CONSTRAINT fk_tour_staff
        FOREIGN KEY (staff_id) REFERENCES staff(staff_id),
    CONSTRAINT chk_tour_people
        CHECK (min_num > 0 AND max_num >= min_num),
    CONSTRAINT chk_tour_expense
        CHECK (expense >= 0 AND deposit >= 0),
    CONSTRAINT chk_tour_dep_yn
        CHECK (dep_yn IN ('Y', 'N')),
    CONSTRAINT chk_tour_date
        CHECK (end_dt > start_dt)
);

CREATE TABLE driver (
    driver_id INTEGER PRIMARY KEY,
    name VARCHAR(20) NOT NULL,
    cell CHAR(13) NOT NULL UNIQUE,
    license_no VARCHAR(20) NOT NULL UNIQUE,
    contract_month INTEGER DEFAULT 12,
    CONSTRAINT chk_driver_contract
        CHECK (contract_month > 0)
);

CREATE TABLE tour_bus (
    bus_id INTEGER PRIMARY KEY,
    bus_no VARCHAR(20) NOT NULL UNIQUE,
    seat_count INTEGER NOT NULL,
    company VARCHAR(50) DEFAULT '자체 운영',
    CONSTRAINT chk_bus_seat
        CHECK (seat_count > 0)
);

CREATE TABLE reserve (
    customer_id VARCHAR(15) NOT NULL,
    tour_num CHAR(8) NOT NULL,
    reserve_dt DATE NOT NULL DEFAULT CURRENT_DATE,
    deposit_paid_yn CHAR(1) NOT NULL DEFAULT 'N',
    cancel_yn CHAR(1) NOT NULL DEFAULT 'N',
    PRIMARY KEY (customer_id, tour_num),
    CONSTRAINT fk_reserve_customer
        FOREIGN KEY (customer_id) REFERENCES customer(id),
    CONSTRAINT fk_reserve_tour
        FOREIGN KEY (tour_num) REFERENCES tour(tour_num),
    CONSTRAINT chk_reserve_deposit_paid
        CHECK (deposit_paid_yn IN ('Y', 'N')),
    CONSTRAINT chk_reserve_cancel
        CHECK (cancel_yn IN ('Y', 'N'))
);

CREATE TABLE assign_driver (
    tour_num CHAR(8) NOT NULL,
    driver_id INTEGER NOT NULL,
    assign_order INTEGER NOT NULL DEFAULT 1,
    PRIMARY KEY (tour_num, driver_id),
    CONSTRAINT fk_assign_driver_tour
        FOREIGN KEY (tour_num) REFERENCES tour(tour_num),
    CONSTRAINT fk_assign_driver_driver
        FOREIGN KEY (driver_id) REFERENCES driver(driver_id),
    CONSTRAINT chk_assign_driver_order
        CHECK (assign_order > 0)
);

CREATE TABLE assign_bus (
    tour_num CHAR(8) NOT NULL,
    bus_id INTEGER NOT NULL,
    assign_order INTEGER NOT NULL DEFAULT 1,
    PRIMARY KEY (tour_num, bus_id),
    CONSTRAINT fk_assign_bus_tour
        FOREIGN KEY (tour_num) REFERENCES tour(tour_num),
    CONSTRAINT fk_assign_bus_bus
        FOREIGN KEY (bus_id) REFERENCES tour_bus(bus_id),
    CONSTRAINT chk_assign_bus_order
        CHECK (assign_order > 0)
);


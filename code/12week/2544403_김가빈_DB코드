-- 4. TEST QUERIES

-- 4-1. Customer Grade Search
-- 사용자가 입력한 고객 id 예시: CUST001
SELECT
    c.id,
    c.name,
    cc.class AS customer_grade
FROM customer c
JOIN class_code cc ON c.c_code = cc.code
WHERE c.id = 'CUST001';

-- 4-2. Employee Task Search
-- 사용자가 입력한 사번 예시: 10003
SELECT
    s.staff_id,
    s.name,
    tc.task AS staff_task
FROM staff s
JOIN task_code tc ON s.t_code = tc.code
WHERE s.staff_id = 10003;

-- 4-3. Tour Reservation Search
-- 사용자가 입력한 여행번호 예시: TOUR0001
SELECT
    t.tour_num,
    t.departure,
    t.arrival,
    c.name AS customer_name,
    r.reserve_dt,
    r.deposit_paid_yn
FROM reserve r
JOIN customer c ON r.customer_id = c.id
JOIN tour t ON r.tour_num = t.tour_num
WHERE r.tour_num = 'TOUR0001'
  AND r.cancel_yn = 'N'
ORDER BY r.reserve_dt;

-- 4-4. Assigned Driver Search
-- 사용자가 입력한 여행번호 예시: TOUR0001
SELECT
    t.tour_num,
    t.departure,
    t.arrival,
    d.name AS driver_name,
    d.cell AS driver_cell
FROM tour t
JOIN assign_driver ad ON t.tour_num = ad.tour_num
JOIN driver d ON ad.driver_id = d.driver_id
WHERE t.tour_num = 'TOUR0001';

